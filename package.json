{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:next": "npm --prefix resources/portfolio2 run dev -- --port 3001",
        "dev:fixme": "npm --prefix \"resources/fix me\" run dev -- --host 127.0.0.1 --port 5174",
        "dev:all": "concurrently -n vite,next -c blue,green \"npm run dev\" \"npm run dev:next\"",
        "dev:apps": "concurrently -n fixme,next -c cyan,green \"npm run dev:fixme\" \"npm run dev:next\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
